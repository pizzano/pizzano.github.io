export function asArray(value) {
  if (Array.isArray(value)) return value.filter(Boolean);
  if (value && typeof value === "object") return Object.values(value).filter(Boolean);
  return [];
}

export function money(value) {
  const num = Number(value || 0);
  return `${num.toLocaleString("nb-NO", { maximumFractionDigits: 0 })},00 kr`;
}

export function shortOrderId(id = "") {
  return String(id || "").slice(-7).toUpperCase();
}

export function cleanPhone(value = "") {
  return String(value || "").replace(/\D/g, "").slice(0, 8);
}

export function makeId(value = "") {
  return String(value || "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "") || `id-${Date.now()}`;
}

export function compactText(value = "", max = 72) {
  const text = String(value || "").trim();
  return text.length > max ? `${text.slice(0, max - 1)}…` : text;
}
